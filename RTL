Traffic_Light.V

`timescale 1ns / 1ps

module traffic_light(
    input clk,
    input rst,
    output reg red,
    output reg yellow,
    output reg green
);

parameter RED    = 2'b00;
parameter GREEN  = 2'b01;
parameter YELLOW = 2'b10;

reg [1:0] state;
reg [2:0] counter;

// State Machine
always @(posedge clk or posedge rst)
begin
    if(rst)
    begin
        state <= RED;
        counter <= 0;
    end
    else
    begin
        case(state)

            RED:
            begin
                if(counter == 4)
                begin
                    state <= GREEN;
                    counter <= 0;
                end
                else
                    counter <= counter + 1;
            end

            GREEN:
            begin
                if(counter == 4)
                begin
                    state <= YELLOW;
                    counter <= 0;
                end
                else
                    counter <= counter + 1;
            end

            YELLOW:
            begin
                if(counter == 1)
                begin
                    state <= RED;
                    counter <= 0;
                end
                else
                    counter <= counter + 1;
            end

            default:
            begin
                state <= RED;
                counter <= 0;
            end

        endcase
    end
end

// Output Logic
always @(*)
begin
    red = 0;
    yellow = 0;
    green = 0;

    case(state)
        RED:    red = 1;
        GREEN:  green = 1;
        YELLOW: yellow = 1;
        default: red = 1;
    endcase
end

endmodule
